MYSQL_DATABASE=econpulse
MYSQL_USER=econpulse
MYSQL_PASSWORD=econpulse
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
REDIS_PORT=6379
SERVER_PORT=8080
ECONPULSE_INTERNAL_MAPPING_REBUILD_ENABLED=false
ECONPULSE_INTERNAL_TERM_NEWS_MAPPING_ENABLED=false
NAVER_NEWS_CLIENT_ID=replace-with-naver-client-id
NAVER_NEWS_CLIENT_SECRET=replace-with-naver-client-secret
NAVER_NEWS_BASE_URL=https://openapi.naver.com
NAVER_NEWS_CONNECT_TIMEOUT=2s
NAVER_NEWS_READ_TIMEOUT=3s
