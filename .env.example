# Local Docker Compose and Spring Boot defaults. Copy to .env and change only locally.
MYSQL_HOST=localhost
MYSQL_PORT=3308
MYSQL_DATABASE=econpulse
MYSQL_USER=econpulse
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

REDIS_HOST=localhost
REDIS_PORT=6379
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# Local uses the deterministic Fake Provider. Naver remains disabled without an explicit override.
ECONPULSE_NEWS_PROVIDER_TYPE=fake
NAVER_NEWS_CLIENT_ID=
NAVER_NEWS_CLIENT_SECRET=

# Internal write APIs are disabled by default. Enable only for an isolated local task.
ECONPULSE_INTERNAL_NEWS_SYNC_ENABLED=false
ECONPULSE_INTERNAL_MAPPING_REBUILD_ENABLED=false
ECONPULSE_INTERNAL_TERM_NEWS_MAPPING_ENABLED=false
